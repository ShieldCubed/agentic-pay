# Copy this file to ".env" in the project root and fill in real values.
# NEVER commit the real .env file to version control.

# ---------- Bitcoin ----------
BTC_NETWORK=testnet
BTC_WIF=
BTC_ESPLORA_URL=https://blockstream.info/testnet/api

# ---------- Ethereum / USDT (ERC-20) / USDC (ERC-20) ----------
ETH_RPC_URL=
ETH_PRIVATE_KEY=
# Leave unset to use mainnet USDT/USDC contract addresses. Override if
# testing on a testnet with different token contracts.
USDT_CONTRACT_ADDRESS=
USDC_CONTRACT_ADDRESS=

# ---------- XRP Ledger ----------
XRP_WSS_URL=wss://s.altnet.rippletest.net:51233
XRP_SEED=

# ---------- Monero ----------
# Point this at a running `monero-wallet-rpc` instance. See
# docs/SETUP_LINUX.md / SETUP_WINDOWS.md / SETUP_MACOS.md for how to start it.
XMR_WALLET_RPC_URL=http://127.0.0.1:18082/json_rpc
XMR_WALLET_RPC_USER=
XMR_WALLET_RPC_PASS=

# ---------- Zcash ----------
# Point this at a running `zcashd` instance's RPC interface.
ZEC_RPC_URL=http://127.0.0.1:8232
ZEC_RPC_USER=
ZEC_RPC_PASS=
ZEC_FROM_ADDRESS=

# ---------- Server ----------
PORT=8787
WEB_PORT=8788
AGENTIC_PAY_DATA_DIR=
AGENTIC_PAY_CONFIG=
AGENTIC_PAY_AGENT_ID=mcp-default-agent
